pkgname=llamatray-git
pkgver=1.0.0
pkgrel=1
pkgdesc="PyQt6 based Llama.cpp Tray Manager for Linux"
arch=('any')
url="https://gitea.fatihdurdu.xyz"
license=('MIT')
depends=('python' 'python-pyqt6' 'python-psutil')
optdepends=('nvidia-ml-py: NVIDIA GPU monitoring support')
source=("git+https://gitea.fatihdurdu.xyz/fatih/LlamaTray.git" "LlamaTray.desktop")
md5sums=('SKIP' 'SKIP')

package() {
    # Hedef dizini oluştur ve Gitea'dan inen tüm LlamaTray klasör yapısını /opt altına kopyala
    install -d "${pkgdir}/opt/LlamaTray"
    cp -r "${srcdir}/LlamaTray/"* "${pkgdir}/opt/LlamaTray/"

    # Sistemin global olarak çalıştırabilmesi için /usr/bin altına başlatıcı symlink ekle
    install -d "${pkgdir}/usr/bin"
    echo -e '#!/bin/bash\npython /opt/LlamaTray/LlamaTray/main.py "$@"' > "${pkgdir}/usr/bin/LlamaTray"
    chmod +x "${pkgdir}/usr/bin/LlamaTray"

    # Masaüstü kısayolunu menüye yerleştir
    install -Dm644 "${srcdir}/LlamaTray.desktop" "${pkgdir}/usr/share/applications/LlamaTray.desktop"
}